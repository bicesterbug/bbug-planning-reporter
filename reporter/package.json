{
  "name": "bbug-reporter",
  "version": "0.1.0",
  "private": true,
  "description": "Cherwell planning transport assessment on Claude Managed Agents (serverless control plane)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "agent:create": "ant beta:agents create < agent/agent.yaml --transform id -r",
    "env:create": "ant beta:environments create < agent/environment.yaml --transform id -r"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "@neondatabase/serverless": "^0.10.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
