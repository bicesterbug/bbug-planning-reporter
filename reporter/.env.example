# ── Anthropic / Managed Agents ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_WEBHOOK_SIGNING_KEY=whsec_...        # used by client.beta.webhooks.unwrap
REPORTER_AGENT_ID=agent_...                    # from `npm run agent:create` (ant CLI)
REPORTER_ENVIRONMENT_ID=env_...                # from `npm run env:create`

# ── Internal wiring ──────────────────────────────────────────────────────────
INTERNAL_TOOL_TOKEN=                           # shared secret: webhook → tool endpoints
REPORTER_BASE_URL=https://reporter.example.org # absolute base for internal tool calls
HUMAN_QUEUE_WEBHOOK_URL=                        # where escalations are posted (optional)

# ── Data layer (managed SaaS) ────────────────────────────────────────────────
DATABASE_URL=postgres://...neon.tech/...        # Neon Postgres + pgvector
VOYAGE_API_KEY=                                 # Voyage AI embeddings
VOYAGE_MODEL=voyage-3
UPSTASH_REDIS_REST_URL=                         # queue + scraper rate-limit state
UPSTASH_REDIS_REST_TOKEN=
BLOB_READ_WRITE_TOKEN=                          # Vercel Blob (downloaded PDFs)

# ── External services ────────────────────────────────────────────────────────
CHERWELL_PORTAL_URL=https://planningregister.cherwell.gov.uk
SCRAPER_USER_AGENT=BBUG-Planning-Reporter/2.0 (+cycling advocacy)
VALHALLA_URL=                                   # hosted Valhalla (e.g. Stadia Maps)
VALHALLA_API_KEY=
ARCGIS_PLANNING_URL=                            # defaults to Cherwell register (see assess_route.py)
